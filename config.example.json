// Example configuration for claude-code-router (Multi-Profile fork).
//
// Copy this file to ~/.claude-code-router/config.json
// (or to ./data/config.json when running in Docker with ./data mounted
// to /root/.claude-code-router), then edit the providers, API keys,
// and profiles to fit your setup.
//
// What this example shows
// -----------------------
// A realistic mixed-provider setup that routes through:
//   - Volcengine      : China-region gateway (Doubao / GLM / Kimi / DeepSeek
//                       hosted in Volcano Engine). OpenAI-compatible API.
//   - OpenCode Go     : a multi-model gateway (Zen) that exposes many
//                       upstreams (Qwen, MiMo, DeepSeek, etc.) behind a
//                       single endpoint with both OpenAI- and Anthropic-
//                       compatible variants. https://opencode.ai/zen
//   - DeepSeek direct : billed directly via the official API.
//   - Anthropic direct: native Anthropic endpoint for Claude.
//
// Four Profiles are defined below (`glm`, `deepseek`, `qwen`, `sonnet`).
// Each appears as `claude-code/<id>` in the Claude Code /model picker.
// When picked, the built-in profile router applies that profile's per-scenario
// routing (default / think / longContext / image / background) for every
// request from that client.
//
// No CUSTOM_ROUTER_PATH is needed: as long as a "Profiles" block is present,
// the router ships inside the package and is wired up automatically. To
// override it with your own routing script, set "CUSTOM_ROUTER_PATH" and it
// takes precedence.
{
  "LOG": true,
  "NON_INTERACTIVE_MODE": true,
  "HOST": "0.0.0.0",
  "APIKEY": "${CCR_API_KEY}",

  "Providers": [
    // ----------------------------------------------------------------
    // Volcengine — Volcano Engine "coding" endpoint.
    // OpenAI-compatible. Hosts GLM / Kimi / DeepSeek in CN region.
    // ----------------------------------------------------------------
    {
      "name": "volcengine",
      "api_base_url": "https://ark.cn-beijing.volces.com/api/coding/v3/chat/completions",
      "api_key": "${VOLCENGINE_API_KEY}",
      "models": [
        "glm-5.1",
        "kimi-k2.6",
        "deepseek-v4-pro"
      ],
      "transformer": {
        "use": ["OpenAI"]
      }
    },

    // ----------------------------------------------------------------
    // OpenCode Go (Zen) — OpenAI-compatible side.
    // https://opencode.ai/zen — one endpoint, many upstreams.
    // ----------------------------------------------------------------
    {
      "name": "opencode-go",
      "api_base_url": "https://opencode.ai/zen/go/v1/chat/completions",
      "api_key": "${OCGO_API_KEY}",
      "models": [
        "qwen3.7-plus",
        "qwen3.7-max",
        "mimo-v2.5-pro",
        "mimo-v2.5"
      ],
      "transformer": {
        "use": ["OpenAI"]
      }
    },

    // OpenCode Go (Zen) — Anthropic-compatible side, used for models that
    // need the native Anthropic protocol (e.g. interleaved thinking).
    {
      "name": "opencode-go-anthropic",
      "api_base_url": "https://opencode.ai/zen/go/v1/messages",
      "api_key": "${OCGO_API_KEY}",
      "models": [
        "deepseek-v4-pro"
      ],
      "transformer": {
        "use": ["Anthropic"]
      }
    },

    // ----------------------------------------------------------------
    // DeepSeek direct — cheapest path billed by the official API.
    // ----------------------------------------------------------------
    {
      "name": "deepseek",
      "api_base_url": "https://api.deepseek.com/chat/completions",
      "api_key": "${DEEPSEEK_API_KEY}",
      "models": [
        "deepseek-v4-pro"
      ],
      "transformer": {
        "use": ["OpenAI"]
      }
    },

    // ----------------------------------------------------------------
    // Anthropic direct — native endpoint for Claude.
    // ----------------------------------------------------------------
    {
      "name": "anthropic",
      "api_base_url": "https://api.anthropic.com/v1/messages",
      "api_key": "${ANTHROPIC_API_KEY}",
      "models": [
        "claude-sonnet-4-5-20250929"
      ],
      "transformer": {
        "use": ["Anthropic"]
      }
    }
  ],

  // Engine safety fallback. When CUSTOM_ROUTER_PATH is set, the real
  // routing lives in "Profiles" below — this Router block only catches
  // requests that bypass the custom router (e.g. health checks).
  "Router": {
    "default": "volcengine,glm-5.1"
  },

  // Shared global fallback chains. When the picked provider/model fails,
  // the router walks down the list for the matching scenario. Only
  // `fallback.default` applies to picker-routed (Profiles) requests;
  // the other scenarios apply when the built-in Router is in charge.
  "fallback": {
    "default": [
      "opencode-go-anthropic,deepseek-v4-pro",
      "deepseek,deepseek-v4-pro"
    ],
    "think": [
      "opencode-go-anthropic,deepseek-v4-pro",
      "deepseek,deepseek-v4-pro"
    ],
    "longContext": [
      "deepseek,deepseek-v4-pro"
    ],
    "background": [
      "opencode-go-anthropic,deepseek-v4-pro",
      "volcengine,glm-5.1"
    ],
    "image": [
      "volcengine,kimi-k2.6",
      "opencode-go,qwen3.7-plus"
    ]
  },

  // ----------------------------------------------------------------
  // Profiles — the heart of this fork.
  //
  // Each key becomes a model id (`claude-code/<key>`) exposed via
  // GET /v1/models. Claude Code lists them in the /model picker when
  // CLAUDE_CODE_ENABLE_GATEWAY_MODEL_DISCOVERY=1 is set in the env.
  //
  // When a profile is picked, the custom router uses *that profile's*
  // per-scenario assignment for every request from that client.
  // ----------------------------------------------------------------
  "DefaultProfile": "glm",

  "Profiles": {
    "glm": {
      "display_name": "GLM-5.1 (Volcengine)",
      "default":            "volcengine,glm-5.1",
      "think":              "volcengine,glm-5.1",
      "longContext":        "opencode-go-anthropic,deepseek-v4-pro",
      "longContextThreshold": 80000,
      "image":              "opencode-go,mimo-v2.5",
      "background":         "volcengine,glm-5.1"
    },

    "deepseek": {
      "display_name": "DeepSeek V4 Pro (OCGO)",
      "default":            "opencode-go-anthropic,deepseek-v4-pro",
      "think":              "opencode-go-anthropic,deepseek-v4-pro",
      "longContext":        "opencode-go-anthropic,deepseek-v4-pro",
      "longContextThreshold": 80000,
      "image":              "opencode-go,mimo-v2.5",
      "background":         "volcengine,glm-5.1"
    },

    "qwen": {
      "display_name": "Qwen 3.7 Max (OCGO)",
      "default":            "opencode-go,qwen3.7-max",
      "think":              "opencode-go,qwen3.7-max",
      "longContext":        "opencode-go,mimo-v2.5-pro",
      "longContextThreshold": 80000,
      "image":              "opencode-go,qwen3.7-plus",
      "background":         "volcengine,glm-5.1"
    },

    "sonnet": {
      "display_name": "Claude Sonnet 4.5",
      "default":            "anthropic,claude-sonnet-4-5-20250929",
      "think":              "anthropic,claude-sonnet-4-5-20250929",
      "longContext":        "anthropic,claude-sonnet-4-5-20250929",
      "longContextThreshold": 120000,
      "image":              "opencode-go,mimo-v2.5",
      "background":         "volcengine,glm-5.1"
    }
  }
}
